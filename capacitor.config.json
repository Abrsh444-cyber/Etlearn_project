{
  "appId": "com.aksum.pro",
  "appName": "Aksum Pro",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "url": "https://app.aksum.pro"
  },
  "ios": {
    "contentInset": "automatic"
  },
  "android": {
    "allowMixedContent": true,
    "webViewDebuggingEnabled": false,
    "buildOptions": {
      "release": true,
      "keystorePath": "./android-release-key.keystore",
      "keystoreAlias": "aksum-pro",
      "keystorePassword": "${KEYSTORE_PASSWORD}",
      "keystoreAliasPassword": "${KEYSTORE_ALIAS_PASSWORD}"
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0
    },
    "CapacitorHttp": {
      "enabled": true
    }
  }
}
